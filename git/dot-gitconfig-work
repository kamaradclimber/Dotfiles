[include]
	path = ~/.dotfiles/git/dot-gitconfig-main
	path = ~/.git-maintenance-config
	path = /Users/gregoire.seux/.config/datadog/git/config
	path = /Users/gregoire.seux/.config/gitsign/gitconfig

[alias]
  # interactive creation of a branch matching common naming pattern <name>/<stack>[/<topic>]
  ddco = "!git-ddco.sh"
  readable-reflog = "!git log -g $(git branch --show-current)"
	review = "!f() { if [ $# -eq 0 ]; then echo \"git review expects one argument (a branch name)\"; exit 1; else if git show-ref --verify --quiet \"refs/heads/$1\"; then git fetch origin \"$1\" && git checkout \"$1\" && git merge --ff-only \"origin/$1\"; else git fetch origin \"$1:$1\" && git checkout \"$1\"; fi; fi; }; f"


[diff]
  tool = diffsitter
  # external = difft

[difftool]
  prompt = false

[difftool "diffsitter"]
  cmd = diffsitter "$LOCAL" "$REMOTE"


[url "git@github.com:"]
    insteadOf = https://github.com/
[core]
	hooksPath = /usr/local/dd/global_hooks

  # following options are especially useful on large repositories
  untrackedCache = true
  fsmonitor = true
  untrackedCache = true
  commitGraph = true



[pager]
  # always display full diff in terminal. It leaves a trace in the terminal!
  # this is better than changing core.pager option which changes all pager including for git log
  diff = cat
  difftool = true
[machete "github"]
	forceDescriptionFromCommitMessage = true
[merge]
	conflictstyle = diff3
[maintenance]
	repo = /private/var/folders/yz/zq7c0r991bl3jmk9chj48ff00000gn/T/trufflehog-1594-2906255904
